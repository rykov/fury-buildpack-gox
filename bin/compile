#!/bin/bash
# usage: bin/compile <build-dir> <cache-dir> <env-dir>

set -eo pipefail

mkdir -p "$1" "$2"
build=$(cd "$1/" && pwd)
cache=$(cd "$2/" && pwd)
env_dir=$3
hostos=$(uname|tr A-Z a-z)
arch=$(uname -m|tr A-Z a-z)
if test $arch = x86_64
then arch=amd64
fi

# -----------------------------------------
# load environment variables
# allow apps to specify cgo flags. The literal text '${build_dir}' is substituted for the build directory
if [ -n "${env_dir}" ]; then
    mkdir -p "${env_dir}"
    env_dir=$(cd "${env_dir}/" && pwd)
    for key in CGO_CFLAGS CGO_CPPFLAGS CGO_CXXFLAGS CGO_LDFLAGS GO_LINKER_SYMBOL GO_LINKER_VALUE GOVERSION GO_OSARCH GO_INSTALL_PACKAGE_SPEC GOPROXY GOPRIVATE GONOPROXY
    do
        if [ -f "${env_dir}/${key}" ]; then
            export "${key}=$(cat "${env_dir}/${key}" | sed -e "s:\${build_dir}:${build}:")"
        fi
    done
fi

# -----------------------------------------
# Go compiler should've been installed by heroku-buildpack-go
# Auto-detect GOROOT from the cache if GOVERSION is not explicitly set

if [ -n "${GOVERSION}" ]; then
    # Explicit version: try both cache layouts
    if [ -d "${cache}/.heroku/go/${GOVERSION}/go" ]; then
        export GOROOT="${cache}/.heroku/go/${GOVERSION}/go"
    elif [ -d "${cache}/${GOVERSION}/go" ]; then
        export GOROOT="${cache}/${GOVERSION}/go"
    else
        echo "-----> ERROR: Could not find Go ${GOVERSION} in cache"
        echo "       Ensure heroku-buildpack-go runs first"
        exit 1
    fi
else
    # Auto-detect: find the Go installation in the cache
    goRoot=""
    for d in "${cache}"/go*/go "${cache}/.heroku/go"/go*/go; do
        if [ -x "${d}/bin/go" ]; then
            goRoot="${d}"
        fi
    done
    if [ -z "${goRoot}" ]; then
        echo "-----> ERROR: Could not find Go installation in cache"
        echo "       Set GOVERSION or ensure heroku-buildpack-go runs first"
        exit 1
    fi
    export GOROOT="${goRoot}"
    echo "-----> Detected Go: $(${GOROOT}/bin/go version)"
fi
PATH="${GOROOT}/bin:${PATH}"

# Build flags
# Default GO_LINKER_VALUE to SOURCE_VERSION if not set via env_dir
: "${GO_LINKER_VALUE:=${SOURCE_VERSION}}"

FLAGS=(-tags heroku)
if [ -n "${GO_LINKER_SYMBOL}" -a -n "${GO_LINKER_VALUE}" ]; then
    FLAGS+=(-ldflags "-X ${GO_LINKER_SYMBOL}=${GO_LINKER_VALUE}")
fi

# Cross-compiling OS/arch pairs (space-separated, e.g. "linux/amd64 darwin/arm64")
osarch="${GO_OSARCH:-${hostos}/$arch}"

# Find package path to build
pkgs=${GO_INSTALL_PACKAGE_SPEC:-$(awk '{ if ($1 == "//" && $2 == "+heroku" && $3 == "install" ) { print substr($0, index($0,$4)); exit }}' "${build}/go.mod")}
if [ -z "${pkgs}" ]; then
    if [ -d "${build}/cmd" ]; then
        pkgs="./cmd/..."
    else
        pkgs="./..."
    fi
fi

# Resolve package list (expand ... patterns)
cd "${build}"
pkgList=$(go list ${pkgs})

# Remove prior build from heroku-buildpack-go
source "${build}/.heroku/go/.meta"
priorBin="${build}/bin/$(basename "$NAME")"
echo "-----> Running: rm ${priorBin}"
rm "${priorBin}"

# Cross-compile each package for each OS/arch pair
for pair in ${osarch}; do
    goos="${pair%%/*}"
    goarch="${pair##*/}"

    for pkg in ${pkgList}; do
        pkgName=$(basename "${pkg}")

        if [ -n "${GO_OSARCH}" ]; then
            output="${build}/bin/${pkgName}-${goos}-${goarch}"
        else
            output="${build}/bin/${pkgName}"
        fi

        echo "-----> Building ${pkg} for ${goos}/${goarch}..."
        cgo=0
        if [ "${goos}" = "${hostos}" ] && [ "${goarch}" = "${arch}" ]; then
            cgo=${CGO_ENABLED:-1}
        fi
        GOOS="${goos}" GOARCH="${goarch}" CGO_ENABLED="${cgo}" \
            go build -o "${output}" "${FLAGS[@]}" "${pkg}" 2>&1
    done
done
